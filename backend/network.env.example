# Copier ce fichier vers backend/network.env puis adapter les valeurs.
# Le fichier backend/network.env est volontairement ignore par Git.

# Base locale SQLite par defaut si DATABASE_URL est absent.
# Pour MySQL en reseau, utiliser l'URL ci-dessous en remplacant le mot de passe et l'IP.
# DATABASE_URL=mysql+pymysql://asset_equity_user:MotDePasseFort@127.0.0.1:3306/asset_equity

# Dossier de donnees de la version reseau. Il est separe du mode local par defaut.
STORAGE_DIR=data\network

# Securite de session et anti-bruteforce.
SESSION_TTL_MINUTES=120
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
LOG_LEVEL=INFO

# Si un nom DNS existe, le mettre ici, par exemple:
# ASSET_EQUITY_PUBLIC_URL=http://assets-equity.local:48620

# HTTPS optionnel, avec certificats deja crees.
# ASSET_EQUITY_SSL_CERTFILE=certs\asset-equity.crt
# ASSET_EQUITY_SSL_KEYFILE=certs\asset-equity.key
